<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- خلفية دائرية داكنة -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1A1A35" />
            <size android:width="108dp" android:height="108dp" />
        </shape>
    </item>
    <!-- حلقة خارجية حمراء -->
    <item
        android:top="8dp"
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp">
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="#FF6B6B" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- دائرة داخلية حمراء -->
    <item
        android:top="22dp"
        android:bottom="22dp"
        android:left="22dp"
        android:right="22dp">
        <shape android:shape="oval">
            <solid android:color="#E94560" />
        </shape>
    </item>
    <!-- مثلث تشغيل أبيض -->
    <item
        android:top="34dp"
        android:bottom="34dp"
        android:left="38dp"
        android:right="30dp">
        <rotate
            android:fromDegrees="0"
            android:toDegrees="0"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFF" />
                <size android:width="20dp" android:height="20dp" />
                <corners android:radius="2dp" />
            </shape>
        </rotate>
    </item>
</layer-list>