<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A35" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:top="10dp"
        android:bottom="10dp"
        android:left="10dp"
        android:right="10dp">
        <shape android:shape="oval">
            <solid android:color="#FF6B6B" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:top="15dp"
        android:bottom="15dp"
        android:left="15dp"
        android:right="15dp">
        <shape android:shape="oval">
            <solid android:color="#E94560" />
        </shape>
    </item>
</layer-list>