<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#FF3A3A"
                android:endColor="#C62828"
                android:type="radial"
                android:gradientRadius="50%"
                android:centerX="50%"
                android:centerY="30%" />
        </shape>
    </item>
    <item
        android:left="24dp"
        android:top="28dp"
        android:right="24dp"
        android:bottom="28dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item
        android:left="32dp"
        android:top="36dp"
        android:right="34dp"
        android:bottom="36dp">
        <rotate android:fromDegrees="0" android:pivotX="50%" android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="#FF3A3A" />
                <size android:width="12dp" android:height="18dp" />
                <corners android:radius="2dp" />
            </shape>
        </rotate>
    </item>
</layer-list>