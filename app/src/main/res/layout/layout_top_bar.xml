<?xml version="1.0" encoding="utf-8"?>
<!-- ✅ القائمة العلوية (الساعة، الواي فاي، الحساب، الإعدادات، البحث، قائمة التنقل) -->
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:alpha="0.96"
        app:cardBackgroundColor="@color/nav_background"
        app:cardElevation="3dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp">

            <ImageView android:id="@+id/account" android:layout_width="32dp" android:layout_height="32dp" android:padding="4dp" android:src="@drawable/ic_account" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusLeft="@id/theme_toggle"/>

            <TextView android:id="@+id/clock_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="18dp" android:text="00:00" android:textColor="@color/text_white" android:textSize="16sp"/>

            <ImageView android:id="@+id/wifi_icon" android:layout_width="20dp" android:layout_height="20dp" android:layout_marginStart="18dp" android:src="@drawable/ic_wifi" android:tint="@color/text_white"/>

            <ImageView android:id="@+id/theme_toggle" android:layout_width="26dp" android:layout_height="26dp" android:padding="3dp" android:layout_marginStart="18dp" android:src="@drawable/ic_theme_dark" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/account" android:nextFocusLeft="@id/settings"/>

            <ImageView android:id="@+id/settings" android:layout_width="28dp" android:layout_height="28dp" android:padding="4dp" android:layout_marginStart="18dp" android:src="@drawable/ic_settings" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/theme_toggle" android:nextFocusLeft="@id/search_icon"/>

            <ImageView android:id="@+id/search_icon" android:layout_width="26dp" android:layout_height="26dp" android:padding="4dp" android:layout_marginStart="18dp" android:src="@drawable/ic_search" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/settings" android:nextFocusLeft="@id/menu_epg"/>

            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView android:id="@+id/menu_epg" style="@style/TvMenuItem" android:text="@string/menu_epg_label" android:nextFocusRight="@id/search_icon" android:nextFocusLeft="@id/menu_series"/>
            <TextView android:id="@+id/menu_series" style="@style/TvMenuItem" android:text="@string/menu_series_label" android:nextFocusRight="@id/menu_epg" android:nextFocusLeft="@id/menu_movies"/>
            <TextView android:id="@+id/menu_movies" style="@style/TvMenuItem" android:text="@string/menu_movies_label" android:nextFocusRight="@id/menu_series" android:nextFocusLeft="@id/menu_live"/>
            <TextView android:id="@+id/menu_live" style="@style/TvMenuItem" android:text="@string/menu_live_label" android:nextFocusRight="@id/menu_movies" android:nextFocusLeft="@id/menu_home" android:nextFocusDown="@id/sidebar_live_button"/>
            <TextView android:id="@+id/menu_home" style="@style/TvMenuItem" android:text="@string/menu_home_label" android:nextFocusRight="@id/menu_live"/>

            <Space android:layout_width="24dp" android:layout_height="1dp"/>

            <FrameLayout
                android:id="@+id/topBarLogoContainer"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:id="@+id/ivTopBarLogoRing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/logo_ring" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/logo_triangle" />

            </FrameLayout>

            <TextView android:id="@+id/app_logo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DAZOU" android:textColor="@color/accent" android:textSize="22sp" android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</merge>
