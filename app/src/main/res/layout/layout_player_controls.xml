<?xml version="1.0" encoding="utf-8"?>
<!-- ✅ شريط تحكم المشغل الكامل — يظهر بس بوضع ملء الشاشة (اسم البرنامج، شريط
التقدم، أزرار التشغيل/التقديم/الصوت/الجودة، وشريط تصفح القنوات المصغّر) -->
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/player_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/player_controls_gradient"
        android:paddingHorizontal="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp"
        app:layout_constraintStart_toStartOf="@id/video_player"
        app:layout_constraintEnd_toEndOf="@id/video_player"
        app:layout_constraintBottom_toBottomOf="@id/video_player">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvControlsNow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvQualityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/search_bg"
                android:textColor="@color/accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:text=""
                android:visibility="gone"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pbControlsProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="6dp"
            android:layoutDirection="ltr"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/accent"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvElapsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_gray"
                android:textSize="10.5sp"
                android:visibility="gone"/>

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:max="1000"
                android:progressDrawable="@drawable/seekbar_style"
                android:thumb="@drawable/seekbar_thumb"
                android:paddingVertical="4dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_gray"
                android:textSize="10.5sp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/liveBadge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/live_badge"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"><ImageView android:id="@+id/btn_prev" android:layout_width="26dp" android:layout_height="26dp" android:padding="3dp" android:src="@drawable/ic_prev" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusLeft="@id/btn_rewind10"/>

            <TextView android:id="@+id/btn_rewind10" android:layout_width="wrap_content" android:layout_height="30dp" android:minWidth="34dp" android:gravity="center" android:layout_marginStart="10dp" android:text="⏪10" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:contentDescription="@string/player_rewind_10" android:nextFocusRight="@id/btn_prev" android:nextFocusLeft="@id/btn_play_pause"/>

            <ImageView android:id="@+id/btn_play_pause" android:layout_width="34dp" android:layout_height="34dp" android:padding="5dp" android:layout_marginStart="10dp" android:src="@drawable/ic_pause" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/btn_rewind10" android:nextFocusLeft="@id/btn_forward10"/>

            <TextView android:id="@+id/btn_forward10" android:layout_width="wrap_content" android:layout_height="30dp" android:minWidth="34dp" android:gravity="center" android:layout_marginStart="10dp" android:text="10⏩" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:contentDescription="@string/player_forward_10" android:nextFocusRight="@id/btn_play_pause" android:nextFocusLeft="@id/btn_next"/>

            <ImageView android:id="@+id/btn_next" android:layout_width="26dp" android:layout_height="26dp" android:padding="3dp" android:layout_marginStart="10dp" android:src="@drawable/ic_next" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/btn_forward10" android:nextFocusLeft="@id/btn_volume_down"/>

            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView android:id="@+id/btn_volume_down" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:text="−" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:contentDescription="@string/player_volume_down" android:nextFocusRight="@id/btn_next" android:nextFocusLeft="@id/btn_volume"/>

            <ImageView android:id="@+id/btn_volume" android:layout_width="24dp" android:layout_height="24dp" android:padding="3dp" android:layout_marginStart="10dp" android:src="@drawable/ic_volume_on" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/btn_volume_down" android:nextFocusLeft="@id/btn_volume_up"/>

            <TextView android:id="@+id/btn_volume_up" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:layout_marginStart="10dp" android:text="+" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:contentDescription="@string/player_volume_up" android:nextFocusRight="@id/btn_volume" android:nextFocusLeft="@id/btn_aspect_ratio"/>

            <TextView android:id="@+id/btn_aspect_ratio" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:layout_marginStart="10dp" android:text="⛶" android:textSize="15sp" android:textColor="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:contentDescription="@string/player_aspect_ratio" android:nextFocusRight="@id/btn_volume_up" android:nextFocusLeft="@id/btn_audio_track"/>

            <TextView android:id="@+id/btn_audio_track" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:layout_marginStart="10dp" android:text="🎧" android:textSize="14sp" android:textColor="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:contentDescription="@string/player_audio_track" android:nextFocusRight="@id/btn_aspect_ratio" android:nextFocusLeft="@id/btn_fullscreen"/>

            <ImageView android:id="@+id/btn_fullscreen" android:layout_width="24dp" android:layout_height="24dp" android:padding="3dp" android:layout_marginStart="10dp" android:src="@drawable/ic_fullscreen_enter" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/btn_audio_track" android:nextFocusLeft="@id/btn_pip"/>
            <ImageView android:id="@+id/btn_pip" android:layout_width="22dp" android:layout_height="22dp" android:padding="2dp" android:layout_marginStart="10dp" android:src="@drawable/ic_pip" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/btn_sleep_timer" android:nextFocusLeft="@id/btn_fullscreen"/>

            <ImageView android:id="@+id/btn_sleep_timer" android:layout_width="22dp" android:layout_height="22dp" android:padding="2dp" android:layout_marginStart="10dp" android:src="@drawable/ic_sleep_timer" android:tint="@color/text_white" android:background="@drawable/icon_focus_selector" android:focusable="true" android:focusableInTouchMode="true" android:clickable="true" android:nextFocusRight="@id/btn_fullscreen" android:nextFocusLeft="@id/btn_pip"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/channelStripScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:visibility="gone">
            <LinearLayout
                android:id="@+id/channelStripTrack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </LinearLayout>

    </LinearLayout>
</merge>
