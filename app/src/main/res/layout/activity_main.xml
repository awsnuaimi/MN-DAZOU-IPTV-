<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:layoutDirection="rtl"
    android:keepScreenOn="true">

    <!-- ✅ القائمة العلوية — مقسّمة لملف مستقل: layout_top_bar.xml -->
    <include layout="@layout/layout_top_bar" />

    <!-- ✅ الشريط الجانبي (الفئات) — مقسّم لملف مستقل: layout_sidebar.xml -->
    <include layout="@layout/layout_sidebar" />

    <!-- ✅ لوحة القنوات — مقسّمة لملف مستقل: layout_channels_panel.xml -->
    <include layout="@layout/layout_channels_panel" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/channels_panel"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/video_player"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/black"
            app:use_controller="false"
            app:resize_mode="fit"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ProgressBar
            android:id="@+id/player_loading"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/accent"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/video_player"
            app:layout_constraintBottom_toBottomOf="@id/video_player"
            app:layout_constraintStart_toStartOf="@id/video_player"
            app:layout_constraintEnd_toEndOf="@id/video_player"/>

        <TextView
            android:id="@+id/channel_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/common_loading"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:background="#88000000"
            android:padding="8dp"
            app:layout_constraintTop_toTopOf="@id/video_player"
            app:layout_constraintStart_toStartOf="@id/video_player"/>

        <!-- ✅ زر التكبير الوحيد اللي بيظهر بالشاشة المصغّرة — باقي المعلومات
        (اسم القناة/الوقت/البرنامج القادم) بتظهر بس تحت باللوحة، مش مكرّرة هون -->
        <ImageView
            android:id="@+id/btnFullscreenSmall"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="6dp"
            android:src="@drawable/ic_fullscreen_enter"
            android:tint="@color/text_white"
            android:background="@drawable/icon_focus_selector"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:contentDescription="@string/player_fullscreen_toggle"
            android:nextFocusUp="@id/menu_home"
            app:layout_constraintBottom_toBottomOf="@id/video_player"
            app:layout_constraintEnd_toEndOf="@id/video_player"
            android:layout_marginBottom="8dp"
            android:layout_marginEnd="8dp"/>

        <!-- ✅ شريط تحكم المشغل الكامل — مقسّم لملف مستقل: layout_player_controls.xml -->
        <include layout="@layout/layout_player_controls" />

        <!-- ✅ زر إعادة المحاولة اليدوي — يظهر بس لما كل محاولات الاتصال التلقائية تفشل -->
        <TextView
            android:id="@+id/btnManualRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/player_retry_now"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_button_pink_selector"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/video_player"
            app:layout_constraintBottom_toBottomOf="@id/video_player"
            app:layout_constraintStart_toStartOf="@id/video_player"
            app:layout_constraintEnd_toEndOf="@id/video_player"/>

        <!-- ✅ شاشة شعار القناة الكبيرة — بتظهر لثانيتين لما تبدل قناة بسرعة (Zapping) -->
        <LinearLayout
            android:id="@+id/zapOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#99000000"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/video_player"
            app:layout_constraintBottom_toBottomOf="@id/video_player"
            app:layout_constraintStart_toStartOf="@id/video_player"
            app:layout_constraintEnd_toEndOf="@id/video_player">

            <ImageView
                android:id="@+id/ivZapLogo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:scaleType="centerInside"
                android:background="@color/panel_darker"/>

            <TextView
                android:id="@+id/tvZapName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text=""/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/live_epg_panel"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:background="@color/panel_dark"
            android:padding="14dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/video_player"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvNowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/live_select_channel_prompt"
                android:textColor="@color/text_white"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <ProgressBar
                android:id="@+id/pbNowProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:layoutDirection="ltr"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/accent"/>

            <TextView
                android:id="@+id/tvNowTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="@color/text_gray"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvNowDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="@color/text_gray"
                android:textSize="12.5sp"
                android:maxLines="3"
                android:ellipsize="end"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvNextTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text=""
                android:textColor="@color/text_gray"
                android:textSize="13sp"/>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/video_player"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ✅ نافذة البحث الشامل — مقسّمة لملف مستقل: layout_search_overlay.xml -->
    <include layout="@layout/layout_search_overlay" />
</androidx.constraintlayout.widget.ConstraintLayout>
