<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/player_height">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000" />

        <TextView
            android:id="@+id/tvChannelInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:background="@color/player_info_bg"
            android:textColor="@color/text_white"
            android:textSize="@dimen/player_info_text_size"
            android:visibility="gone"
            android:padding="8dp" />

        <LinearLayout
            android:id="@+id/controlsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@color/control_bg"
            android:visibility="gone"
            android:layout_gravity="bottom"
            android:padding="4dp">

            <Button android:id="@+id/btnPrevChannel" style="@style/PlayerControlButton" android:text="⏪" />
            <Button android:id="@+id/btnPlayPause" style="@style/PlayerControlButton" android:text="▶️" />
            <Button android:id="@+id/btnNextChannel" style="@style/PlayerControlButton" android:text="⏩" />
            <Button android:id="@+id/btnEpg" style="@style/PlayerControlButton" android:text="📋" />
            <Button android:id="@+id/btnAspectRatio" style="@style/PlayerControlButton" android:text="🔲" />
            <Button android:id="@+id/btnToggleFullscreen" style="@style/PlayerControlButton" android:text="⛶" />
            <Button android:id="@+id/btnRecord" style="@style/PlayerControlButton" android:text="🔴" />
            <Button android:id="@+id/btnShare" style="@style/PlayerControlButton" android:text="📤" />
            <Button android:id="@+id/btnDownload" style="@style/PlayerControlButton" android:text="⬇️" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bottom_bar"
        android:gravity="center">

        <Button android:id="@+id/btnHome" style="@style/TabButton" android:text="🏠 الرئيسية" />
        <Button android:id="@+id/btnLive" style="@style/TabButton" android:text="📺 مباشر" />
        <Button android:id="@+id/btnMovies" style="@style/TabButton" android:text="🎬 أفلام" />
        <Button android:id="@+id/btnSeries" style="@style/TabButton" android:text="🎭 مسلسلات" />
        <Button android:id="@+id/btnFavorites" style="@style/TabButton" android:text="⭐ مفضلة" />
        <Button android:id="@+id/btnAccounts" style="@style/TabButton" android:text="👤 حسابات" />
    </LinearLayout>
</LinearLayout>