<!-- themes.xml -->
<resources>
    <style name="Theme.MN_DAZOU" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#FF6B6B</item>
        <item name="colorPrimaryDark">#0F0F1A</item>
    </style>
</resources>

<!-- styles.xml -->
<resources>
    <style name="TvTabButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/tv_tab_selector</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>
    <style name="TvMenuItem">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textSize">@dimen/tv_tab_text_size</item>
        <item name="android:padding">8dp</item>
    </style>
</resources>